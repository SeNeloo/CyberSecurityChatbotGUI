 <Window x:Class="CyberSecurityChatbotGUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cybersecurity Awareness Bot"
        Height="600"
        Width="900"
        Background="#1E1E2F">
 <Grid>
       <Grid Background="#FF7DBACA">

    <Label Content="Cybersecurity Awareness Bot"
           HorizontalAlignment="Center"
           Margin="10,10,10,10"
           VerticalAlignment="Top"
           FontSize="34" FontWeight="Bold"/>

    <RichTextBox x:Name="rtbChat"
                 Margin="20,60,20,100"
                 IsReadOnly="True" TextChanged="rtbChat_TextChanged"/>

    <TextBox x:Name="txtUserInput"
             HorizontalAlignment="Left"
             Height="60"
             Margin="20,0,120,20"
             VerticalAlignment="Bottom"
             Width="400"/>

    <Button x:Name="btnSend"
            Content="Send"
            HorizontalAlignment="Right"
            Margin="0,0,20,20"
            VerticalAlignment="Bottom"
            Width="80"
            Height="45"
            Click="btnSend_Click" FontWeight="Bold" FontFamily="Segoe UI Variable Display" FontSize="14"/>
            </Grid>
            </Grid>
</Window>
   
