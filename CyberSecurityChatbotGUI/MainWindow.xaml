 <Window x:Class="CyberSecurityChatbotGUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cybersecurity Awareness Bot"
        Height="600"
        Width="1000"
        Background="#1E1E2F">
 
        <Grid>
            <TabControl x:Name="tabMain" Margin="10">

                
                <TabItem Header="Chatbot">
                    <Grid Background="#FF7DBACA">

                        <Label Content="Cybersecurity Awareness Bot"
                       HorizontalAlignment="Center"
                       Margin="0,6,0,0"
                       VerticalAlignment="Top"
                       FontSize="36"
                       FontWeight="Bold"/>

                        <RichTextBox x:Name="rtbChat"
                             Margin="20,60,20,100"
                             IsReadOnly="True"
                             TextChanged="rtbChat_TextChanged"/>

                        <TextBox x:Name="txtUserInput"
                         HorizontalAlignment="Left"
                         Height="60"
                         Margin="20,0,120,20"
                         VerticalAlignment="Bottom"
                         Width="400"/>

                        <Button x:Name="btnSend"
                        Content="Send"
                        HorizontalAlignment="Right"
                        Margin="0,0,20,20"
                        VerticalAlignment="Bottom"
                        Width="80"
                        Height="45"
                        Click="btnSend_Click"/>
                    </Grid>
                </TabItem>

               
                <TabItem Header="Tasks">
                    <Grid Margin="10">

                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBox x:Name="txtTaskTitle"
                         Height="30"
                         Margin="5"/>

                        <TextBox x:Name="txtTaskDescription"
                         Grid.Row="1"
                         Height="30"
                         Margin="5"/>

                        <DatePicker x:Name="dpReminder"
                            Grid.Row="2"
                            Margin="5"/>

                        <StackPanel Grid.Row="2"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right">

                            <Button x:Name="btnAddTask"
                            Content="Add Task"
                            Width="100"
                            Margin="5"
                            Click="btnAddTask_Click"/>

                            <Button x:Name="btnDeleteTask"
                            Content="Delete"
                            Width="100"
                            Margin="5"
                            Click="btnDeleteTask_Click"/>

                        <Button x:Name="btnCompleteTask"
                         Content="Complete"
                         Width="100"
                         Margin="5"
                         Click="btnCompleteTask_Click"/>
                    </StackPanel>

                        <DataGrid x:Name="dgTasks"
                          Grid.Row="3"
                          Margin="5"
                          AutoGenerateColumns="True"/>
                    </Grid>
                </TabItem>

                
                <TabItem Header="Quiz">
                <Grid Margin="20">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Label x:Name="lblQuestion"
                           FontSize="22"
                           FontWeight="Bold"
                           Margin="10"/>

                    <TextBox x:Name="txtQuizAnswer"
                             Grid.Row="1"
                             Height="35"
                             Margin="10"/>

                    <Button x:Name="btnSubmitAnswer"
                            Grid.Row="2"
                            Content="Submit Answer"
                            Height="40"
                            Margin="10"
                            Click="btnSubmitAnswer_Click"/>

                    <Label x:Name="lblScore"
                           Grid.Row="3"
                           FontSize="18"
                           FontWeight="Bold"
                           Margin="10"/>
                </Grid>

            </TabItem>

                
                <TabItem Header="Activity Log">
                    <Grid>
                        <ListBox x:Name="lstActivityLog"
                         Margin="10"/>
                    </Grid>
                </TabItem>

            </TabControl>
        </Grid>
</Window>
   
