<Window x:Class="CyberSecurityChatbotGUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cybersecurity Awareness Bot"
        Height="600"
        Width="1000"
        Background="#1E1E2F">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition Width="124*"/>
        </Grid.ColumnDefinitions>
        <Grid Background="#FF7DBACA" Grid.ColumnSpan="2">

            <Label Content="Cybersecurity Awareness Bot"
           HorizontalAlignment="Center"
           Margin="0,6,0,0"
           VerticalAlignment="Top"
           FontSize="36" FontWeight="Bold"/>

            <RichTextBox x:Name="rtbChat"
                 Margin="20,60,20,100"
                 IsReadOnly="True" TextChanged="rtbChat_TextChanged"/>

            <TextBox x:Name="txtUserInput"
             HorizontalAlignment="Left"
             Height="60"
             Margin="20,0,120,20"
             VerticalAlignment="Bottom"
             Width="400"/>

            <Button x:Name="btnSend"
            Content="Send"
            HorizontalAlignment="Right"
            Margin="0,0,20,20"
            VerticalAlignment="Bottom"
            Width="80"
            Height="45"
            Click="btnSend_Click" FontWeight="Bold" FontFamily="Segoe UI Variable Display" FontSize="14"/>
        </Grid>
    </Grid>
</Window>
   
